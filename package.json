{
  "name": "@tokimo/sdk",
  "version": "0.1.0",
  "description": "SDK for third-party Tokimo apps: shell context, React hooks, and viewer exports.",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./react": "./src/react-hooks.ts",
    "./viewers": "./src/viewers/index.ts"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@tokimo/viewers": "workspace:*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.2",
    "vitest": "^4.0.0"
  }
}
